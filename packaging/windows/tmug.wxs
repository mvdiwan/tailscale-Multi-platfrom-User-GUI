<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">

  <!-- tMUG - Tailscale Multi-platform User GUI
       By DEC-LLC (Diwan Enterprise Consulting LLC)
       License: Apache-2.0

       Build on Linux:  wixl -o tMUG-1.3.0-setup.msi tmug.wxs
       Install on Win:  msiexec /i tMUG-1.3.0-setup.msi
       Uninstall:       msiexec /x tMUG-1.3.0-setup.msi

       NOTE: The standalone .exe must be built with PyInstaller first.
             See build-exe.sh or the GitHub Actions workflow.
  -->

  <Product Id="*"
           Name="tMUG - Tailscale Multi-platform User GUI"
           Language="1033"
           Version="1.3.0.0"
           Manufacturer="DEC-LLC (Diwan Enterprise Consulting LLC)"
           UpgradeCode="7A3B9C4D-5E6F-4A8B-9C0D-1E2F3A4B5C6D">

    <Package InstallerVersion="200"
             Compressed="yes"
             InstallScope="perMachine"
             Description="tMUG v1.3.0 — GUI for managing Tailscale VPN"
             Comments="Standalone application — no Python installation required"
             Manufacturer="DEC-LLC (Diwan Enterprise Consulting LLC)" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of tMUG is already installed." />

    <Media Id="1" Cabinet="tmug.cab" EmbedCab="yes" />

    <!-- Directory layout -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLDIR" Name="tMUG">

          <Component Id="MainFiles" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">
            <File Id="TailscaleManagerExe"
                  Name="tMUG-tailscale-manager.exe"
                  Source="dist/tMUG-tailscale-manager.exe"
                  KeyPath="yes" />
            <File Id="IconFile"
                  Name="tmug.ico"
                  Source="tmug.ico" />
            <File Id="LicenseFile"
                  Name="LICENSE"
                  Source="../../LICENSE" />
            <File Id="ReadmeFile"
                  Name="README.md"
                  Source="../../README.md" />
          </Component>

        </Directory>
      </Directory>

      <!-- Start Menu -->
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ProgramMenuDir" Name="tMUG">
          <Component Id="StartMenuShortcuts" Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901">
            <Shortcut Id="StartMenuShortcut"
                      Name="tMUG"
                      Description="Tailscale Multi-platform User GUI"
                      Target="[INSTALLDIR]tMUG-tailscale-manager.exe"
                      WorkingDirectory="INSTALLDIR"
                      Icon="tmug.ico" />
            <Shortcut Id="UninstallShortcut"
                      Name="Uninstall tMUG"
                      Target="[SystemFolder]msiexec.exe"
                      Arguments="/x [ProductCode]" />
            <RemoveFolder Id="RemoveProgramMenuDir" On="uninstall" />
            <RegistryValue Root="HKCU"
                           Key="Software\DEC-LLC\tMUG"
                           Name="installed"
                           Type="integer"
                           Value="1"
                           KeyPath="yes" />
          </Component>
        </Directory>
      </Directory>

      <!-- Desktop shortcut -->
      <Directory Id="DesktopFolder">
        <Component Id="DesktopShortcut" Guid="C3D4E5F6-A7B8-9012-CDEF-123456789012">
          <Shortcut Id="DesktopShortcutLink"
                    Name="tMUG"
                    Description="Tailscale Multi-platform User GUI"
                    Target="[INSTALLDIR]tMUG-tailscale-manager.exe"
                    WorkingDirectory="INSTALLDIR"
                    Icon="tmug.ico" />
          <RegistryValue Root="HKCU"
                         Key="Software\DEC-LLC\tMUG"
                         Name="desktopshortcut"
                         Type="integer"
                         Value="1"
                         KeyPath="yes" />
        </Component>
      </Directory>
    </Directory>

    <!-- Icon for shortcuts -->
    <Icon Id="tmug.ico" SourceFile="tmug.ico" />

    <!-- Install all components -->
    <Feature Id="Complete" Title="tMUG" Level="1">
      <ComponentRef Id="MainFiles" />
      <ComponentRef Id="StartMenuShortcuts" />
      <ComponentRef Id="DesktopShortcut" />
    </Feature>

  </Product>
</Wix>
